*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f4f4;
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
}

.container{
width:90%;
max-width:500px;
background:#fff;
padding:20px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,.2);
}

h1{
text-align:center;
margin-bottom:20px;
}

.input-box{
display:flex;
gap:10px;
margin-bottom:20px;
}

#taskInput{
flex:1;
padding:10px;
font-size:16px;
}

#addBtn{
padding:10px 20px;
background:#007bff;
color:#fff;
border:none;
cursor:pointer;
border-radius:5px;
}

#addBtn:hover{
background:#0056b3;
}

.filters{
display:flex;
justify-content:space-between;
margin-bottom:20px;
}

.filter-btn{
padding:8px 15px;
border:none;
background:#ddd;
cursor:pointer;
border-radius:5px;
}

.filter-btn:hover{
background:#bbb;
}

#taskList{
list-style:none;
}

.task{
display:flex;
justify-content:space-between;
align-items:center;
padding:10px;
margin-bottom:10px;
background:#f8f8f8;
border-radius:5px;
}

.task.completed span{
text-decoration:line-through;
color:gray;
}

.actions button{
margin-left:5px;
padding:5px 10px;
border:none;
cursor:pointer;
border-radius:4px;
}

.complete-btn{
background:green;
color:white;
}

.edit-btn{
background:orange;
color:white;
}

.delete-btn{
background:red;
color:white;
}

@media(max-width:600px){

.input-box{
flex-direction:column;
}

.filters{
flex-direction:column;
gap:10px;
}

.task{
flex-direction:column;
align-items:flex-start;
gap:10px;
}

.actions{
display:flex;
gap:5px;
}

}
